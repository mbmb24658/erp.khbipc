generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model WBS {
  id                    String               @id @default(cuid())
  wbsCode               String               @unique
  title                 String
  parentId              String?
  level                 Int                  @default(1)
  hierarchyPath         String               @default("")
  durationDays          Int                  @default(0)
  progressPlan          Float                @default(0)
  progressActual        Float                @default(0)
  startDate             DateTime?
  finishDate            DateTime?
  startDateJalali       String?
  finishDateJalali      String?
  actualCost            Float?
  costVariance          Float?
  scheduleVariance      Float?
  hrPlan                String?
  hrActual              String?
  dayComplete           Float?
  requiredOrgPositionId String?
  urgency               String   @default("normal")
  priority              Int      @default(3)
  description           String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  activities            Activity[]
  assets                Asset[]
  budgets               BudgetAllocation[]
  costs                 CostBreakdown[]
  kpis                  KPI[]
  revenues              RevenueBreakdown[]
  risks                 Risk[]
  parent                WBS?                 @relation("WBSHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children              WBS[]                @relation("WBSHierarchy")
  requiredOrgPosition   OrgChart?            @relation("WBSRequiredOrgPosition", fields: [requiredOrgPositionId], references: [id])
  monthlyProgress       WBSMonthlyProgress[]
  orgPositions          WBSOrgChart[]
  personels             WBSPersonel[]
}

model WBSPersonel {
  id         String   @id @default(cuid())
  wbsId      String
  personelId String
  role       String?
  allocation Float?
  createdAt  DateTime @default(now())
  personel   Personel @relation(fields: [personelId], references: [id], onDelete: Cascade)
  wbs        WBS      @relation(fields: [wbsId], references: [id], onDelete: Cascade)

  @@unique([wbsId, personelId])
}

model WBSOrgChart {
  id         String   @id @default(cuid())
  wbsId      String
  orgChartId String
  createdAt  DateTime @default(now())
  orgChart   OrgChart @relation(fields: [orgChartId], references: [id], onDelete: Cascade)
  wbs        WBS      @relation(fields: [wbsId], references: [id], onDelete: Cascade)

  @@unique([wbsId, orgChartId])
}

model WBSMonthlyProgress {
  id         String   @id @default(cuid())
  wbsId      String
  monthDate  DateTime
  plannedPct Float    @default(0)
  actualPct  Float?
  createdAt  DateTime @default(now())
  wbs        WBS      @relation(fields: [wbsId], references: [id], onDelete: Cascade)

  @@unique([wbsId, monthDate])
}

model Personel {
  id                    String                 @id @default(cuid())
  personelId            String                 @unique
  name                  String
  orgChartId            String?
  costBreakdownCode     String?
  phone                 String?
  email                 String?
  role                  String                 @default("user")
  gender                String?
  monthlySalary         Float?
  annualSalary          Float?
  monthlySalaryActual   Float?
  annualSalaryActual    Float?
  dailyRate             Float?
  notes                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  costBreakdownId       String?
  activityAssignments   ActivityPerson[]
  activityStatusUpdates ActivityStatusUpdate[] @relation("ActivityStatusUpdater")
  kpiAssignments        KPIAssignment[]
  kpiEvaluationsDone    KPIEvaluation[]        @relation("KPIEvaluatedBy")
  kpiEvaluations        KPIEvaluation[]        @relation("KPIEvaluatedPerson")
  kpiRecords            KPIRecord[]
  lessonsCaptured       LessonLearned[]        @relation("LessonCapturedBy")
  orgChartResponsible   OrgChart?              @relation("OrgChartResponsible")
  costBreakdown         CostBreakdown?         @relation(fields: [costBreakdownId], references: [id])
  orgChart              OrgChart?              @relation(fields: [orgChartId], references: [id])
  risksIdentified       Risk[]                 @relation("RiskIdentifiedBy")
  riskActions           RiskAction[]
  riskEvaluationsDone   RiskEvaluation[]       @relation("RiskEvaluatedBy")
  riskChanges           RiskHistory[]
  user                  User?
  wbsAssignments        WBSPersonel[]
}

model OrgChart {
  id                  String             @id @default(cuid())
  orgId               String             @unique
  position            String
  level               String
  parentId            String?
  personResponsibleId String?            @unique
  costBreakdownCode   String?
  hrPositionId        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  activityAssignments ActivityOrgChart[]
  kpis                KPI[]
  kpiEvaluations      KPIEvaluation[]
  parent              OrgChart?          @relation("OrgChartHierarchy", fields: [parentId], references: [id])
  children            OrgChart[]         @relation("OrgChartHierarchy")
  personResponsible   Personel?          @relation("OrgChartResponsible", fields: [personResponsibleId], references: [id])
  personels           Personel[]
  wbsRequiredBy       WBS[]              @relation("WBSRequiredOrgPosition")
  wbsLinks            WBSOrgChart[]
}

model CostBreakdown {
  id              String             @id @default(cuid())
  costId          String             @unique
  rowNumber       String?
  budgetType      String?
  category        String?
  description     String?
  theme           String?
  initialForecast Float?
  programForecast Float?
  percentTotal    Float?
  notes           String?
  wbsId           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  budgets         BudgetAllocation[]
  wbs             WBS?               @relation(fields: [wbsId], references: [id])
  personels       Personel[]
}

model RevenueBreakdown {
  id              String   @id @default(cuid())
  revenueId       String   @unique
  rowNumber       String?
  theme           String?
  description     String?
  title           String?
  wbsCode         String?
  wbsId           String?
  initialForecast Float?
  programForecast Float?
  ownershipShare  Float?
  percentTotal    Float?
  revenueType     String?
  status          String?
  progressPct     Float?
  actualRevenue   Float?
  ev              Float?
  trlLevel        Int?
  assetId         String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  asset           Asset?   @relation("AssetRevenues", fields: [assetId], references: [id])
  wbs             WBS?     @relation(fields: [wbsId], references: [id])
}

model BudgetAllocation {
  id              String         @id @default(cuid())
  wbsId           String?
  costBreakdownId String?
  fiscalYear      String?
  plannedAmount   Float?
  actualAmount    Float?
  variance        Float?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  costBreakdown   CostBreakdown? @relation(fields: [costBreakdownId], references: [id])
  wbs             WBS?           @relation(fields: [wbsId], references: [id])
}

model Executor {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  type          String?
  nationalId    String?
  phone         String?
  email         String?
  address       String?
  contactPerson String?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  assets        Asset[]
}

model Asset {
  id           String             @id @default(cuid())
  assetId      String             @unique
  title        String
  category     String?
  description  String?
  status       String?
  assetType    String?
  wbsId        String?
  executorId   String?
  purchaseDate DateTime?
  initialValue Float?
  actualValue  Float?
  currentValue Float?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  activities   Activity[]
  executor     Executor?          @relation(fields: [executorId], references: [id])
  wbs          WBS?               @relation(fields: [wbsId], references: [id])
  evaluations  AssetEvaluation[]
  revenues     RevenueBreakdown[] @relation("AssetRevenues")
  risks        Risk[]
}

model AssetEvaluation {
  id             String   @id @default(cuid())
  assetId        String
  evaluationDate DateTime @default(now())
  evaluator      String?
  technicalScore Float?
  businessScore  Float?
  overallScore   Float?
  comments       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model KPI {
  id          String          @id @default(cuid())
  code        String          @unique
  title       String
  description String?
  category    String?
  weight      Float           @default(1.0)
  targetValue Float?
  unit        String?
  frequency   String?
  orgChartId  String?
  wbsId       String?
  status      String          @default("active")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  orgChart    OrgChart?       @relation(fields: [orgChartId], references: [id])
  wbs         WBS?            @relation(fields: [wbsId], references: [id])
  assignments KPIAssignment[]
}

model KPIAssignment {
  id         String      @id @default(cuid())
  kpiId      String
  personelId String
  status     String      @default("active")
  startDate  DateTime?
  endDate    DateTime?
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  kpi        KPI         @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  personel   Personel    @relation(fields: [personelId], references: [id], onDelete: Cascade)
  records    KPIRecord[]

  @@unique([kpiId, personelId])
}

model KPIRecord {
  id            String        @id @default(cuid())
  assignmentId  String
  recordDate    DateTime      @default(now())
  value         Float
  notes         String?
  confirmedById String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  assignment    KPIAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  confirmedBy   Personel?     @relation(fields: [confirmedById], references: [id])
}

model Risk {
  id             String           @id @default(cuid())
  code           String           @unique
  title          String
  description    String?
  category       String?
  status         String           @default("open")
  probability    Int?
  impact         Int?
  severity       Int?
  riskType       String?
  wbsId          String?
  assetId        String?
  identifiedById String?
  identifiedDate DateTime         @default(now())
  dueDate        DateTime?
  resolutionDate DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  lessons        LessonLearned[]
  asset          Asset?           @relation(fields: [assetId], references: [id])
  identifiedBy   Personel?        @relation("RiskIdentifiedBy", fields: [identifiedById], references: [id])
  wbs            WBS?             @relation(fields: [wbsId], references: [id])
  actions        RiskAction[]
  evaluations    RiskEvaluation[]
  history        RiskHistory[]
}

model RiskAction {
  id            String    @id @default(cuid())
  riskId        String
  title         String
  description   String?
  status        String    @default("pending")
  assignedToId  String?
  dueDate       DateTime?
  completedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignedTo    Personel? @relation(fields: [assignedToId], references: [id])
  risk          Risk      @relation(fields: [riskId], references: [id], onDelete: Cascade)
}

model RiskHistory {
  id          String    @id @default(cuid())
  riskId      String
  changeDate  DateTime  @default(now())
  changeType  String?
  oldValue    String?
  newValue    String?
  changedById String?
  notes       String?
  createdAt   DateTime  @default(now())
  changedBy   Personel? @relation(fields: [changedById], references: [id])
  risk        Risk      @relation(fields: [riskId], references: [id], onDelete: Cascade)
}

model NotificationTemplate {
  id              String         @id @default(cuid())
  code            String         @unique
  title           String
  subjectTemplate String?
  bodyTemplate    String
  category        String?
  variables       String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  notifications   Notification[]
}

model Notification {
  id         String                @id @default(cuid())
  templateId String?
  userId     String?
  title      String
  message    String
  category   String?
  priority   String                @default("normal")
  isRead     Boolean               @default(false)
  readAt     DateTime?
  actionUrl  String?
  metadata   String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  template   NotificationTemplate? @relation(fields: [templateId], references: [id])
}

model NotificationConfig {
  id          String   @id @default(cuid())
  userId      String?
  category    String
  channel     String
  isEnabled   Boolean  @default(true)
  minPriority String   @default("normal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChartConfig {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  chartType   String?
  dataSource  String?
  config      String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChartCache {
  id            String    @id @default(cuid())
  chartConfigId String?
  cacheKey      String    @unique
  data          String
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model DashboardWidget {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  widgetType  String?
  dataSource  String?
  config      String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DashboardConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  layout    String?
  settings  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DashboardAlert {
  id             String    @id @default(cuid())
  title          String
  description    String?
  alertType      String?
  severity       String    @default("normal")
  source         String?
  sourceId       String?
  isActive       Boolean   @default(true)
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String?   @unique
  passwordHash String
  personelId   String?   @unique
  roleId       String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  personel     Personel? @relation(fields: [personelId], references: [id])
  role         Role?     @relation(fields: [roleId], references: [id])
  logs         UserLog[]
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String?
  description String?
  category    String?
  isEditable  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  description String?
  ipAddress   String?
  userAgent   String?
  metadata    String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
}

model KPITemplate {
  id           String          @id @default(cuid())
  positionCode String          @unique
  positionName String
  description  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  categories   KPICategory[]
  evaluations  KPIEvaluation[]
}

model KPICategory {
  id         String         @id @default(cuid())
  templateId String
  name       String
  order      Int            @default(0)
  createdAt  DateTime       @default(now())
  template   KPITemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  indicators KPIIndicator[]
}

model KPIIndicator {
  id          String                @id @default(cuid())
  categoryId  String
  name        String
  description String?
  weight      Float                 @default(1.0)
  targetValue Float?
  unit        String?
  order       Int                   @default(0)
  createdAt   DateTime              @default(now())
  records     KPIEvaluationRecord[]
  category    KPICategory           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model KPIEvaluation {
  id              String                @id @default(cuid())
  templateId      String
  personelId      String?
  orgChartId      String?
  period          String
  periodType      String                @default("monthly")
  status          String                @default("draft")
  totalScore      Float?
  maxScore        Float?
  percentageScore Float?
  notes           String?
  evaluatedById   String?
  evaluatedAt     DateTime              @default(now())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  evaluatedBy     Personel?             @relation("KPIEvaluatedBy", fields: [evaluatedById], references: [id])
  orgChart        OrgChart?             @relation(fields: [orgChartId], references: [id])
  personel        Personel?             @relation("KPIEvaluatedPerson", fields: [personelId], references: [id])
  template        KPITemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  records         KPIEvaluationRecord[]
}

model KPIEvaluationRecord {
  id           String        @id @default(cuid())
  evaluationId String
  indicatorId  String
  value        Float
  targetValue  Float?
  score        Float?
  weight       Float?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  evaluation   KPIEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  indicator    KPIIndicator  @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
}

model RiskEvaluation {
  id                 String    @id @default(cuid())
  riskId             String
  period             String
  periodType         String    @default("monthly")
  impactCurrent      String?
  probabilityCurrent String?
  levelCurrent       String?
  impactTarget       String?
  probabilityTarget  String?
  levelTarget        String?
  response           String?
  impactType         String    @default("منفی")
  physicalProgress   Float?
  notes              String?
  evaluatedById      String?
  evaluatedAt        DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  evaluatedBy        Personel? @relation("RiskEvaluatedBy", fields: [evaluatedById], references: [id])
  risk               Risk      @relation(fields: [riskId], references: [id], onDelete: Cascade)
}

model LessonLearned {
  id              String    @id @default(cuid())
  riskId          String?
  title           String
  description     String
  category        String?
  impact          String?
  recommendations String?
  capturedById    String?
  capturedAt      DateTime  @default(now())
  isArchived      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  capturedBy      Personel? @relation("LessonCapturedBy", fields: [capturedById], references: [id])
  risk            Risk?     @relation(fields: [riskId], references: [id])
}

model Activity {
  id                String                 @id @default(cuid())
  code              String                 @unique
  title             String
  description       String?
  assetId           String?
  wbsId             String?
  startDate         DateTime?
  endDate           DateTime?
  durationDays      Int?
  urgency           String                 @default("normal")
  priority          Int                    @default(3)
  status            String                 @default("pending")
  progressPct       Float                  @default(0)
  createdById       String?
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  hrActual          String?
  hrPlan            String?
  asset             Asset?                 @relation(fields: [assetId], references: [id])
  wbs               WBS?                   @relation(fields: [wbsId], references: [id])
  orgAssignments    ActivityOrgChart[]
  personAssignments ActivityPerson[]
  statusUpdates     ActivityStatusUpdate[]
}

model ActivityPerson {
  id         String   @id @default(cuid())
  activityId String
  personelId String
  role       String?
  assignedAt DateTime @default(now())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  personel   Personel @relation(fields: [personelId], references: [id], onDelete: Cascade)

  @@unique([activityId, personelId])
}

model ActivityOrgChart {
  id         String   @id @default(cuid())
  activityId String
  orgChartId String
  role       String?
  assignedAt DateTime @default(now())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  orgChart   OrgChart @relation(fields: [orgChartId], references: [id], onDelete: Cascade)

  @@unique([activityId, orgChartId])
}

model ActivityStatusUpdate {
  id             String    @id @default(cuid())
  activityId     String
  personelId     String?
  previousStatus String?
  newStatus      String
  progressPct    Float?
  notes          String?
  updatedAt      DateTime  @default(now())
  createdAt      DateTime  @default(now())
  activity       Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  personel       Personel? @relation("ActivityStatusUpdater", fields: [personelId], references: [id])
}
