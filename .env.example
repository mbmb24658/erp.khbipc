# ============================================================
# .env.example — Kharazmi Management System
# ============================================================
# Copy this file to .env and fill in the values.
#
# For LOCAL DEVELOPMENT (SQLite):
#   DATABASE_URL=file:./db/custom.db
#   (no need for DIRECT_URL or DATABASE_PROVIDER)
#
# For VERCEL DEPLOYMENT (PostgreSQL):
#   DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
#   DIRECT_URL=postgresql://user:password@host:port/database?sslmode=require
#   (set these in Vercel dashboard → Settings → Environment Variables)
# ============================================================

# Local SQLite (default for development)
DATABASE_URL=file:./db/custom.db

# For PostgreSQL (uncomment and fill for Vercel):
# DATABASE_URL=postgresql://user:password@host:5432/kharazmi?schema=public
# DIRECT_URL=postgresql://user:password@host:5432/kharazmi?schema=public

# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=kharazmi-secret-key-2026-change-this-in-production

# For production:
# NEXTAUTH_URL=https://your-app.vercel.app
# NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>
